# ---- HeyGen (server-side) ----
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=
HEYGEN_KNOWLEDGE_BASE_ID=

# ---- HeyGen hosted-embed fallback (client-side) ----
# Public HeyGen share URL we render when our primary API is unhealthy.
# Copy from the `share=...` token inside HeyGen's embed snippet.
NEXT_PUBLIC_HEYGEN_FALLBACK_EMBED_URL=https://labs.heygen.com/guest/streaming-embed?share=REPLACE_ME&inIFrame=1

# ---- Iframe embedding ----
# Space-separated list of parent origins allowed to embed this app.
ALLOWED_PARENT_ORIGINS=https://www.zaptest.com https://zaptest.com

# ---- Health monitor (client-side) ----
NEXT_PUBLIC_HEALTH_POLL_INTERVAL_MS=30000
NEXT_PUBLIC_HEALTH_FAILURE_THRESHOLD=2

# ---- Database ----
DATABASE_URL=file:./dev.db

# ---- Phase 2 placeholders ----
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
OPENAI_API_KEY=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
LINKEDIN_CONVERSION_ID=
ADMIN_USERNAME=
ADMIN_PASSWORD_HASH=
